{"name":"xingchen","private":true,"version":"0.0.0","type":"module","scripts":{"dev":"npm run build:shaders && vite","build":"npm run build:shaders && vite build","build:shaders":"cargo build --release && for file in src/modules/shaders/*.wgsl; do npx tgpu-gen \"$file\" --output \"src/modules/shaders/gen/$(basename $file .wgsl).ts\" --overwrite; done","build:shaders:watch":"npx tgpu-gen src/modules/shaders/*.wgsl --output src/modules/shaders/gen/*.ts --watch","preview":"vite preview","type-check":"vue-tsc --noEmit"},"dependencies":{"hammerjs":"^2.0.8","three":"^0.160.0","vue":"^3.4.0"},"devDependencies":{"@types/hammerjs":"^2.0.45","@vitejs/plugin-vue":"^5.0.0","tgpu-gen":"^0.2.0","typegpu":"^0.6.0","typescript":"^5.3.0","vite":"^5.0.0","vue-tsc":"^1.8.0"}}